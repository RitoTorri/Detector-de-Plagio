{
  "name": "detector-de-plagio",
  "version": "1.0.0",
  "description": "APIrest de detección de plagio entre dos textos.",
  "main": "src/index.js",
  "scripts": {
    "install:prod": "npm ci --omit=dev",
    "install:all": "npm install",

    "start:docker": "node src/index.js",
    "dev:docker": "nodemon src/index.js",

    "start:local": "node --env-file=.env src/index.js",
    "dev:local": "cross-env NODE_ENV=development nodemon --env-file=.env src/index.js",

    "image:build": "docker compose build --no-cache",
    "image:run": "docker compose up",

    "test": "cross-env NODE_ENV=test NODE_OPTIONS=--experimental-vm-modules --env-file=.env jest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RitoTorri/Detector-de-Plagio"
  },
  "author": "Jesus Cortez",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/RitoTorri/Detector-de-Plagio/issues"
  },
  "homepage": "https://github.com/RitoTorri/Detector-de-Plagio#readme",
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "similarity": "^1.2.1",
    "string-similarity-js": "^2.1.4"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "dotenv": "^17.2.3",
    "jest": "^30.2.0",
    "nodemon": "^3.1.11",
    "supertest": "^7.1.4"
  }
}
